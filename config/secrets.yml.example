llm:
  dashscope_api_key: REPLACE_ME
  anthropic_api_key: REPLACE_ME
push:
  tg_bot_token_us: REPLACE_ME
  tg_chat_id_us: REPLACE_ME
  tg_bot_token_cn: REPLACE_ME
  tg_chat_id_cn: REPLACE_ME
  # Telegram webhook secret token — set via setWebhook secret_token param.
  # The server checks X-Telegram-Bot-Api-Secret-Token header against this value.
  # Leave empty to disable auth (development only).
  tg_secret_token_us: REPLACE_ME
  tg_secret_token_cn: REPLACE_ME
  # Feishu event-subscription verification token (classic scheme).
  # The server checks the `token` field in the incoming Feishu event body.
  # Leave empty to disable auth (development only).
  feishu_verification_token: REPLACE_ME
  feishu_hook_us: REPLACE_ME
  feishu_sign_us: REPLACE_ME
  feishu_hook_cn: REPLACE_ME
  feishu_sign_cn: REPLACE_ME
storage:
  # feishu_app_id / feishu_app_secret are reused by the chart-image upload path
  # in pushers/feishu.py — fill them even if you don't want the bitable archive.
  feishu_app_id: REPLACE_ME
  feishu_app_secret: REPLACE_ME
  # Archive (bitable writeback) is OPTIONAL.
  # Leave feishu_app_token (and tables) as REPLACE_ME → archive disabled, main
  # pipeline (scrape→LLM→push) runs fine. SQLite is the source of truth; bitable
  # is just a "second brain" for browsing.
  # Common gotcha: bitables in 飞书个人云空间 (URL "feishu.cn/base/...") cannot be
  # written by self-built apps. Move the bitable to a 共享/团队空间 first.
  # app_token is from URL: https://xxx.feishu.cn/base/<APP_TOKEN>?table=...
  # Both US/CN tables share the same app_token if in the same base.
  feishu_app_token: REPLACE_ME
  feishu_table_us: REPLACE_ME
  feishu_table_cn: REPLACE_ME
sources:
  finnhub_token: REPLACE_ME
  tushare_token: REPLACE_ME
  xueqiu_cookie: REPLACE_ME
  ths_cookie: REPLACE_ME
alert:
  bark_url: https://api.day.app/REPLACE_ME
